{
  "name": "@oh-my-pi/feishu-im",
  "version": "1.0.0",
  "description": "飞书 IM 集成插件 - 通过飞书机器人远程操控 OMP",
  "type": "module",
  "main": "./index.ts",
  "scripts": {
    "test": "bun test",
    "check": "bun check"
  },
  "keywords": ["oh-my-pi", "omp", "feishu", "lark", "im", "bot"],
  "author": "oh-my-pi team",
  "license": "MIT",
  "omp": {
    "pi": {
      "name": "feishu-im",
      "version": "1.0.0",
      "description": "飞书 IM 集成插件 - 通过飞书机器人远程操控 OMP",
      "hooks": ["./src/index.ts"],
      "commands": [],
      "extensions": [],
      "settings": {
        "feishuAppId": {
          "type": "string",
          "description": "飞书应用 App ID",
          "required": true
        },
        "feishuAppSecret": {
          "type": "string",
          "description": "飞书应用 App Secret",
          "required": true
        },
        "feishuVerificationToken": {
          "type": "string",
          "description": "飞书事件订阅 Verification Token",
          "required": false,
          "default": ""
        },
        "feishuEncryptKey": {
          "type": "string",
          "description": "飞书事件订阅 Encrypt Key（可选）",
          "required": false,
          "default": ""
        },
        "feishuCallbackUrl": {
          "type": "string",
          "description": "飞书事件回调 URL（需要公网可访问）",
          "required": false,
          "default": ""
        }
      }
    }
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.35.0"
  },
  "devDependencies": {
    "@oh-my-pi/coding-agent": "workspace:*"
  }
}